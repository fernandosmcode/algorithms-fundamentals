algoritmo "testes"
var
 a:inteiro
 b:real
 c:real
 d:real
 f:real
 g:real
inicio

 a <- abs(-50)
 b <- exp(9, 5)
 c <- raizq(81)
 d <- int(raizq(90))
 f <- grauprad(90)
 g <- sen(grauprad(90))
 escreval("Absoluto: ",a)
 escreval("ExponenciańŃo: ",b)
 escreval("Raiz Quadrada: ",c)
 escreval("O valor inteiro da raiz quadrada: ",d)
 escreval("Grau para rad: ",f)
 escreval("Seno: ",g)

fimalgoritmo